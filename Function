#include <stdio.h>
int add(int a, int b)
{return a + b;
}int sub(int a, int b)
{return a - b;
}
int mul(int a, int b)
{return a * b;}

float divi(int a, int b)
{ return (float)a / b;}
int main()
{int a, b, choice;
    printf("Enter two numbers: ");
    scanf("%d%d", &a, &b);
 printf("\n1. Addition");
    printf("\n2. Subtraction");
    printf("\n3. Multiplication");
    printf("\n4. Division");
    printf("\nEnter your choice: ");
    scanf("%d", &choice);
switch(choice)
    { case 1:
            printf("Addition = %d", add(a, b));
            break;

        case 2:
            printf("Subtraction = %d", sub(a, b));
            break;
case 3:
            printf("Multiplication = %d", mul(a, b));
            break;
case 4:
            printf("Division = %.2f", divi(a, b));
            break;
default:
            printf("Invalid Choice");
    }
return 0;}
